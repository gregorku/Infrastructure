###############################################################################
#
# Infrastructure Project
#
# File:
#   .env.example
#
# Description:
#   Example environment configuration for the Infrastructure stack.
#
###############################################################################

###############################################################################
# General
###############################################################################

TZ=Europe/Prague

###############################################################################
# Docker Compose
###############################################################################

COMPOSE_PROJECT_NAME=infrastructure

###############################################################################
# Traefik
###############################################################################

TRAEFIK_VERSION=v3.5

# Public e-mail used for Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@example.com

# Public dashboard hostname
TRAEFIK_DOMAIN=traefik.example.com

###############################################################################
# CrowdSec
###############################################################################

CROWDSEC_VERSION=latest

###############################################################################
# Watchtower
###############################################################################

WATCHTOWER_VERSION=latest

###############################################################################
# Static IP addresses
###############################################################################

IP_TRAEFIK=10.40.0.10
IP_CROWDSEC=10.40.0.11

# Optional second interface (public / DMZ network)
IP_TRAEFIK_PUBLIC=100.40.0.10

###############################################################################
# Persistent data
###############################################################################

INFRASTRUCTURE_DATA=/zfs-data/infrastructure-data

###############################################################################
# Logging
###############################################################################

LOG_MAX_SIZE=20m
LOG_MAX_FILES=5