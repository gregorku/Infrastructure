###############################################################################
#
# Infrastructure Project
#
# File:
#   .env.example
#
# Description:
#   Example environment configuration.
#
###############################################################################

###############################################################################
# General
###############################################################################

TZ=Europe/Prague

###############################################################################
# Docker Compose
###############################################################################

COMPOSE_PROJECT_NAME=infrastructure

###############################################################################
# Traefik
###############################################################################

TRAEFIK_VERSION=v3.5

TRAEFIK_ACME_EMAIL=admin@example.com

TRAEFIK_DOMAIN=traefik.example.com

###############################################################################
# CrowdSec
###############################################################################

CROWDSEC_VERSION=latest

###############################################################################
# Metabase
###############################################################################

METABASE_VERSION=latest

###############################################################################
# Watchtower
###############################################################################

WATCHTOWER_VERSION=latest

###############################################################################
# Docker Networks
###############################################################################

NETWORK_INTERNAL=bridge-moje

NETWORK_TRAEFIK=traefik-moje

###############################################################################
# Static IP
###############################################################################

#
# Internal Docker network
#

IP_TRAEFIK=10.40.0.10

IP_CROWDSEC=10.40.0.11

#
# Public Traefik network
#

IP_TRAEFIK_PUBLIC=100.40.0.10

###############################################################################
# Persistent data
###############################################################################

INFRASTRUCTURE_DATA=/zfs-data/infrastructure-data

###############################################################################
# Logging
###############################################################################

LOG_MAX_SIZE=20m

LOG_MAX_FILES=5